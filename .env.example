# .env.example — copiar como .env y completar valores
# NUNCA commitear el .env real

# PostgreSQL
POSTGRES_USER=arbitrage_user
POSTGRES_PASSWORD=<contraseña fuerte>
POSTGRES_DB=arbitrage_db
DATABASE_URL=postgresql+asyncpg://arbitrage_user:<password>@db:5432/arbitrage_db

# Redis
REDIS_URL=redis://cache:6379/0

# Seguridad JWT
ADMIN_EMAIL=operador@dominio.com
ADMIN_PASSWORD=<secrets.token_urlsafe(20)>
ACCESS_TOKEN_SECRET=<secrets.token_urlsafe(32)>
REFRESH_TOKEN_SECRET=<secrets.token_urlsafe(32)>
ALLOWED_ORIGINS=https://tudominio.com
ENVIRONMENT=production

# Exchanges (opcionales — feeds públicos por defecto)
BINANCE_API_KEY=
BINANCE_SECRET=
BYBIT_API_KEY=
BYBIT_SECRET=
KRAKEN_API_KEY=
KRAKEN_SECRET=

# Configuración operacional (fallback si no está en DB)
INITIAL_CAPITAL_USDT=10000
MIN_PROFIT_THRESHOLD_PCT=0.15

# Logging
LOG_LEVEL=INFO
